<%- include("../partials/head", { pageTitle }) %>
<%- include("../partials/header") %>
<%- include("../partials/flash") %>

<main class="container py-5">
  <section class="hero-card mb-4">
    <div class="row g-4 align-items-center">
      <div class="col-lg-8">
        <p class="eyebrow">Личный кабинет</p>
        <h1 class="display-6 fw-bold mb-2"><%= currentUser.fullName %></h1>
        <p class="text-muted mb-3">
          Логин: <strong><%= currentUser.login %></strong> • Телефон: <strong><%= currentUser.phone %></strong>
        </p>
        <div class="hero-points">
          <div class="hero-point">Контроль статусов обучения</div>
          <div class="hero-point">Заявки по видам транспорта</div>
          <div class="hero-point">Отзывы по завершенным курсам</div>
        </div>
      </div>
      <div class="col-lg-4">
        <div class="dashboard-promo">
          <img src="/assets/pier.jpg" alt="Причал" />
          <a href="/applications/new" class="btn btn-primary btn-lg w-100 mt-3">Оформить новую заявку</a>
        </div>
      </div>
    </div>
  </section>

  <section class="row g-4">
    <div class="col-xl-8">
      <div id="trainingSlider" class="carousel slide slider-shell mb-4" data-bs-ride="carousel" data-bs-interval="3000">
        <div class="carousel-indicators slider-indicators">
          <button type="button" data-bs-target="#trainingSlider" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Слайд 1"></button>
          <button type="button" data-bs-target="#trainingSlider" data-bs-slide-to="1" aria-label="Слайд 2"></button>
          <button type="button" data-bs-target="#trainingSlider" data-bs-slide-to="2" aria-label="Слайд 3"></button>
          <button type="button" data-bs-target="#trainingSlider" data-bs-slide-to="3" aria-label="Слайд 4"></button>
        </div>
        <div class="carousel-inner slider-frame">
          <div class="carousel-item active">
            <img src="/assets/hero-boat.png" class="d-block w-100 slider-image" alt="Скоростной катер" />
          </div>
          <div class="carousel-item">
            <img src="/assets/liner.png" class="d-block w-100 slider-image" alt="Круизный лайнер" />
          </div>
          <div class="carousel-item">
            <img src="/assets/pier.jpg" class="d-block w-100 slider-image" alt="Речная пристань" />
          </div>
          <div class="carousel-item">
            <img src="/assets/slide-4.png" class="d-block w-100 slider-image" alt="Морская прогулка" />
          </div>
        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#trainingSlider" data-bs-slide="prev">
          <span class="carousel-control-prev-icon" aria-hidden="true"></span>
          <span class="visually-hidden">Предыдущий</span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#trainingSlider" data-bs-slide="next">
          <span class="carousel-control-next-icon" aria-hidden="true"></span>
          <span class="visually-hidden">Следующий</span>
        </button>
      </div>

      <div class="glass-panel h-100">
        <div class="section-title-row">
          <div>
            <p class="eyebrow mb-1">История обращений</p>
            <h2 class="h4 mb-0">Мои заявки</h2>
          </div>
        </div>

        <% if (applications.length === 0) { %>
          <p class="text-muted mb-0">Заявок пока нет. Создайте первую заявку на обучение.</p>
        <% } else { %>
          <div class="table-responsive desktop-table">
            <table class="table table-theme align-middle mb-0">
              <thead>
                <tr>
                  <th>ID</th>
                  <th>Транспорт</th>
                  <th>Старт</th>
                  <th>Оплата</th>
                  <th>Статус</th>
                  <th>Отзыв</th>
                </tr>
              </thead>
              <tbody>
                <% applications.forEach((application) => { %>
                  <tr>
                    <td>#<%= application.id %></td>
                    <td><%= application.transportType %></td>
                    <td><%= application.startDateFormatted %></td>
                    <td><%= application.paymentMethod %></td>
                    <td>
                      <span class="status-pill status-<%= application.status.replace(/\s+/g, '-').toLowerCase() %>">
                        <%= application.status %>
                      </span>
                    </td>
                    <td>
                      <% if (application.reviewId) { %>
                        <div class="small">
                          <strong><%= application.reviewRating %>/5</strong><br />
                          <span class="text-muted"><%= application.reviewContent %></span>
                        </div>
                      <% } else { %>
                        <span class="text-muted small">Отзыв еще не оставлен</span>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
          <div class="mobile-cards">
            <% applications.forEach((application) => { %>
              <article class="mobile-info-card">
                <div class="mobile-card-head">
                  <strong>#<%= application.id %> • <%= application.transportType %></strong>
                  <span class="status-pill status-<%= application.status.replace(/\s+/g, '-').toLowerCase() %>">
                    <%= application.status %>
                  </span>
                </div>
                <dl class="mobile-card-grid mb-0">
                  <div>
                    <dt>Старт</dt>
                    <dd><%= application.startDateFormatted %></dd>
                  </div>
                  <div>
                    <dt>Оплата</dt>
                    <dd><%= application.paymentMethod %></dd>
                  </div>
                  <div class="w-100">
                    <dt>Отзыв</dt>
                    <dd>
                      <% if (application.reviewId) { %>
                        <strong><%= application.reviewRating %>/5</strong> — <%= application.reviewContent %>
                      <% } else { %>
                        Отзыв еще не оставлен
                      <% } %>
                    </dd>
                  </div>
                </dl>
              </article>
            <% }) %>
          </div>
        <% } %>
      </div>
    </div>

    <div class="col-xl-4">
      <div class="glass-panel mb-4">
        <p class="eyebrow mb-1">Обратная связь</p>
        <h2 class="h4">Оставить отзыв</h2>

        <% if (reviewableApplications.length === 0) { %>
          <p class="text-muted mb-0">
            Отзыв можно оставить после завершения обучения по заявке.
          </p>
        <% } else { %>
          <form action="/reviews" method="post">
            <div class="mb-3">
              <label class="form-label" for="applicationId">Завершенная заявка</label>
              <select class="form-select <%= reviewFormState.hasFieldError('applicationId') ? 'is-invalid' : '' %>" id="applicationId" name="applicationId">
                <% reviewableApplications.forEach((application) => { %>
                  <option
                    value="<%= application.id %>"
                    <%= String(reviewFormState.fields.applicationId) === String(application.id) ? "selected" : "" %>
                  >
                    #<%= application.id %> • <%= application.transportType %> • <%= application.startDateFormatted %>
                  </option>
                <% }) %>
              </select>
              <% if (reviewFormState.hasFieldError("applicationId")) { %>
                <div class="invalid-feedback d-block"><%= reviewFormState.getFieldError("applicationId") %></div>
              <% } %>
            </div>

            <div class="mb-3">
              <label class="form-label" for="rating">Оценка</label>
              <select class="form-select <%= reviewFormState.hasFieldError('rating') ? 'is-invalid' : '' %>" id="rating" name="rating">
                <% [5, 4, 3, 2, 1].forEach((value) => { %>
                  <option value="<%= value %>" <%= String(reviewFormState.fields.rating) === String(value) ? "selected" : "" %>>
                    <%= value %>/5
                  </option>
                <% }) %>
              </select>
              <% if (reviewFormState.hasFieldError("rating")) { %>
                <div class="invalid-feedback d-block"><%= reviewFormState.getFieldError("rating") %></div>
              <% } %>
            </div>

            <div class="mb-3">
              <label class="form-label" for="content">Текст отзыва</label>
              <textarea class="form-control <%= reviewFormState.hasFieldError('content') ? 'is-invalid' : '' %>" id="content" name="content" rows="5"><%= reviewFormState.fields.content %></textarea>
              <% if (reviewFormState.hasFieldError("content")) { %>
                <div class="invalid-feedback d-block"><%= reviewFormState.getFieldError("content") %></div>
              <% } %>
            </div>

            <button type="submit" class="btn btn-primary w-100">Сохранить отзыв</button>
          </form>
        <% } %>
      </div>

      <div class="glass-panel">
        <p class="eyebrow mb-1">Архив отзывов</p>
        <h2 class="h4">Мои отзывы</h2>

        <% if (reviews.length === 0) { %>
          <p class="text-muted mb-0">Пока нет сохраненных отзывов.</p>
        <% } else { %>
          <div class="review-list">
            <% reviews.forEach((review) => { %>
              <article class="review-card">
                <div class="d-flex justify-content-between align-items-center gap-2 mb-2">
                  <strong><%= review.transportType %></strong>
                  <span class="badge text-bg-primary"><%= review.rating %>/5</span>
                </div>
                <p class="mb-2"><%= review.content %></p>
                <small class="text-muted"><%= review.startDateFormatted %></small>
              </article>
            <% }) %>
          </div>
        <% } %>
      </div>
    </div>
  </section>
</main>

<%- include("../partials/footer") %>
