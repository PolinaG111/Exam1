<%- include("../partials/head", { pageTitle }) %>
<%- include("../partials/header") %>
<%- include("../partials/flash") %>

<main class="container py-5">
  <section class="hero-card mx-auto">
    <div class="row g-4 align-items-stretch">
      <div class="col-xl-4">
        <div class="feature-panel h-100">
          <p class="eyebrow">Новая заявка</p>
          <h1 class="display-6 fw-bold mb-3">Оформление обучения</h1>
          <p class="text-muted mb-4">
            Выберите формат обучения и способ оплаты. После отправки заявка автоматически уйдет на согласование.
          </p>

          <img class="feature-image feature-image-photo mb-4" src="/assets/liner.png" alt="Круизный лайнер" />

          <div class="feature-note">
            <strong>Стартовый статус:</strong>
            <span>каждая новая заявка создается в состоянии «Новая».</span>
          </div>

          <a href="/dashboard" class="btn btn-outline-primary mt-4">Вернуться в кабинет</a>
        </div>
      </div>

      <div class="col-xl-8">
        <form action="/applications" method="post" class="row g-3 glass-panel h-100">
          <div class="col-md-4">
            <label class="form-label" for="transportType">Вид транспорта</label>
            <select class="form-select <%= formState.hasFieldError('transportType') ? 'is-invalid' : '' %>" id="transportType" name="transportType">
              <option value="">Выберите вариант</option>
              <% transportTypes.forEach((transportType) => { %>
                <option value="<%= transportType %>" <%= formState.fields.transportType === transportType ? "selected" : "" %>>
                  <%= transportType %>
                </option>
              <% }) %>
            </select>
            <% if (formState.hasFieldError("transportType")) { %>
              <div class="invalid-feedback d-block"><%= formState.getFieldError("transportType") %></div>
            <% } %>
          </div>

          <div class="col-md-4">
            <label class="form-label" for="startDate">Предпочтительная дата старта</label>
            <input
              class="form-control <%= formState.hasFieldError('startDate') ? 'is-invalid' : '' %>"
              id="startDate"
              name="startDate"
              type="text"
              inputmode="numeric"
              maxlength="10"
              placeholder="ДД.ММ.ГГГГ"
              value="<%= formState.fields.startDate %>"
              data-date-mask="ru"
            />
            <div class="form-hint">Например: 18.07.2026</div>
            <% if (formState.hasFieldError("startDate")) { %>
              <div class="invalid-feedback d-block"><%= formState.getFieldError("startDate") %></div>
            <% } %>
          </div>

          <div class="col-md-4">
            <label class="form-label" for="paymentMethod">Способ оплаты</label>
            <select class="form-select <%= formState.hasFieldError('paymentMethod') ? 'is-invalid' : '' %>" id="paymentMethod" name="paymentMethod">
              <option value="">Выберите вариант</option>
              <% paymentMethods.forEach((paymentMethod) => { %>
                <option value="<%= paymentMethod %>" <%= formState.fields.paymentMethod === paymentMethod ? "selected" : "" %>>
                  <%= paymentMethod %>
                </option>
              <% }) %>
            </select>
            <% if (formState.hasFieldError("paymentMethod")) { %>
              <div class="invalid-feedback d-block"><%= formState.getFieldError("paymentMethod") %></div>
            <% } %>
          </div>

          <div class="col-12">
            <button type="submit" class="btn btn-primary">Отправить заявку</button>
          </div>
        </form>
      </div>
    </div>
  </section>
</main>

<%- include("../partials/footer") %>
