<header class="site-header">
  <nav class="navbar navbar-expand-lg">
    <div class="container">
      <a class="navbar-brand" href="/">Водить.РФ</a>

      <div class="d-flex align-items-center gap-2 ms-auto flex-wrap">
        <% if (currentUser) { %>
          <a class="btn btn-outline-light btn-sm" href="/dashboard">Личный кабинет</a>
          <a class="btn btn-light btn-sm" href="/applications/new">Новая заявка</a>
          <form action="/logout" method="post" class="m-0">
            <button type="submit" class="btn btn-outline-light btn-sm">Выйти</button>
          </form>
        <% } else if (isAdmin) { %>
          <a class="btn btn-light btn-sm" href="/admin/dashboard">Все заявки</a>
          <form action="/admin/logout" method="post" class="m-0">
            <button type="submit" class="btn btn-outline-light btn-sm">Выйти</button>
          </form>
        <% } else { %>
          <a class="btn btn-outline-light btn-sm" href="/login">Войти</a>
          <a class="btn btn-light btn-sm" href="/register">Регистрация</a>
          <a class="btn btn-outline-light btn-sm" href="/admin/login">Администратор</a>
        <% } %>
      </div>
    </div>
  </nav>
</header>
