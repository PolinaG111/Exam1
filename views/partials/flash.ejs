<% if (flash) { %>
  <div class="container mt-4">
    <div class="alert alert-<%= flash.type === 'success' ? 'success' : 'danger' %> shadow-sm mb-0">
      <%= flash.message %>
    </div>
  </div>
<% } %>

<% if (errors && errors.length > 0) { %>
  <div class="container mt-4">
    <div class="alert alert-danger shadow-sm mb-0">
      <ul class="mb-0 ps-3">
        <% errors.forEach((error) => { %>
          <li><%= error.msg %></li>
        <% }) %>
      </ul>
    </div>
  </div>
<% } %>
