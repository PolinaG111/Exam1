<%- include("../partials/head", { pageTitle }) %>
<%- include("../partials/header") %>
<%- include("../partials/flash") %>

<main class="container py-5">
  <section class="hero-card auth-card mx-auto">
    <div class="row g-4 align-items-center">
      <div class="col-lg-6">
        <p class="eyebrow">Регистрация пользователя</p>
        <h1 class="display-6 fw-bold mb-3">Создание учетной записи</h1>
        <p class="text-muted mb-0">
          Укажите обязательные персональные данные для доступа к оформлению заявок и истории обучения.
        </p>
        <img class="feature-image feature-image-logo mt-4" src="/assets/logo.jpg" alt="Бренд Водить.РФ" />
      </div>

      <div class="col-lg-6">
        <form action="/register" method="post" class="row g-3 glass-panel">
          <div class="col-md-6">
            <label class="form-label" for="login">Логин</label>
            <input
              class="form-control <%= formState.hasFieldError('login') ? 'is-invalid' : '' %>"
              id="login"
              name="login"
              type="text"
              value="<%= formState.fields.login %>"
              placeholder="Только латиница и цифры, от 6 символов"
            />
            <div class="form-hint">Минимум 6 символов: латинские буквы и цифры.</div>
            <% if (formState.hasFieldError("login")) { %>
              <div class="invalid-feedback d-block"><%= formState.getFieldError("login") %></div>
            <% } %>
          </div>

          <div class="col-md-6">
            <label class="form-label" for="password">Пароль</label>
            <input
              class="form-control <%= formState.hasFieldError('password') ? 'is-invalid' : '' %>"
              id="password"
              name="password"
              type="password"
              placeholder="Не менее 8 символов"
            />
            <div class="form-hint">Используйте надежный пароль длиной от 8 символов.</div>
            <% if (formState.hasFieldError("password")) { %>
              <div class="invalid-feedback d-block"><%= formState.getFieldError("password") %></div>
            <% } %>
          </div>

          <div class="col-12">
            <label class="form-label" for="fullName">ФИО</label>
            <input
              class="form-control <%= formState.hasFieldError('fullName') ? 'is-invalid' : '' %>"
              id="fullName"
              name="fullName"
              type="text"
              value="<%= formState.fields.fullName %>"
            />
            <% if (formState.hasFieldError("fullName")) { %>
              <div class="invalid-feedback d-block"><%= formState.getFieldError("fullName") %></div>
            <% } %>
          </div>

          <div class="col-md-4">
            <label class="form-label" for="birthDate">Дата рождения</label>
            <input
              class="form-control <%= formState.hasFieldError('birthDate') ? 'is-invalid' : '' %>"
              id="birthDate"
              name="birthDate"
              type="date"
              value="<%= formState.fields.birthDate %>"
            />
            <% if (formState.hasFieldError("birthDate")) { %>
              <div class="invalid-feedback d-block"><%= formState.getFieldError("birthDate") %></div>
            <% } %>
          </div>

          <div class="col-md-4">
            <label class="form-label" for="phone">Телефон</label>
            <input
              class="form-control <%= formState.hasFieldError('phone') ? 'is-invalid' : '' %>"
              id="phone"
              name="phone"
              type="tel"
              value="<%= formState.fields.phone %>"
            />
            <% if (formState.hasFieldError("phone")) { %>
              <div class="invalid-feedback d-block"><%= formState.getFieldError("phone") %></div>
            <% } %>
          </div>

          <div class="col-md-4">
            <label class="form-label" for="email">E-mail</label>
            <input
              class="form-control <%= formState.hasFieldError('email') ? 'is-invalid' : '' %>"
              id="email"
              name="email"
              type="email"
              value="<%= formState.fields.email %>"
            />
            <% if (formState.hasFieldError("email")) { %>
              <div class="invalid-feedback d-block"><%= formState.getFieldError("email") %></div>
            <% } %>
          </div>

          <div class="col-12">
            <button type="submit" class="btn btn-primary">Зарегистрироваться</button>
          </div>
        </form>

        <p class="mt-3 mb-0 text-center">
          <a href="/login" class="link-accent">Уже зарегистрированы? Войти</a>
        </p>
      </div>
    </div>
  </section>
</main>

<%- include("../partials/footer") %>
