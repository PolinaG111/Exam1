<%- include("../partials/head", { pageTitle }) %>
<%- include("../partials/header") %>
<%- include("../partials/flash") %>

<section class="container pb-2">
  <div id="loginSlider" class="carousel slide slider-shell slider-shell-login" data-bs-ride="carousel" data-bs-interval="3000">
    <div class="carousel-indicators slider-indicators">
      <button type="button" data-bs-target="#loginSlider" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Слайд 1"></button>
      <button type="button" data-bs-target="#loginSlider" data-bs-slide-to="1" aria-label="Слайд 2"></button>
      <button type="button" data-bs-target="#loginSlider" data-bs-slide-to="2" aria-label="Слайд 3"></button>
      <button type="button" data-bs-target="#loginSlider" data-bs-slide-to="3" aria-label="Слайд 4"></button>
    </div>
    <div class="carousel-inner slider-frame">
      <div class="carousel-item active">
        <img src="/assets/login-slide-1.jpeg" class="d-block w-100 slider-image" alt="Речное обучение: слайд 1" />
      </div>
      <div class="carousel-item">
        <img src="/assets/login-slide-2.jpeg" class="d-block w-100 slider-image" alt="Речное обучение: слайд 2" />
      </div>
      <div class="carousel-item">
        <img src="/assets/login-slide-3.jpeg" class="d-block w-100 slider-image" alt="Речное обучение: слайд 3" />
      </div>
      <div class="carousel-item">
        <img src="/assets/login-slide-4.jpeg" class="d-block w-100 slider-image" alt="Речное обучение: слайд 4" />
      </div>
    </div>
    <button class="carousel-control-prev" type="button" data-bs-target="#loginSlider" data-bs-slide="prev">
      <span class="carousel-control-prev-icon" aria-hidden="true"></span>
      <span class="visually-hidden">Предыдущий</span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#loginSlider" data-bs-slide="next">
      <span class="carousel-control-next-icon" aria-hidden="true"></span>
      <span class="visually-hidden">Следующий</span>
    </button>
  </div>
</section>

<main class="container py-5">
  <section class="hero-card auth-card mx-auto">
    <div class="row g-4 align-items-center">
      <div class="col-lg-6">
        <p class="eyebrow">Авторизация пользователя</p>
        <h1 class="display-6 fw-bold mb-3">Вход в портал записи на курсы управления водным транспортом</h1>
        <p class="text-muted mb-0">
          Записывайтесь на обучение по катерам, яхтам и круизным лайнерам в одном личном кабинете.
        </p>
        <img class="feature-image feature-image-logo mt-4" src="/assets/logo.jpg" alt="Бренд Водить.РФ" />
      </div>

      <div class="col-lg-6">
        <form action="/login" method="post" class="glass-panel">
          <div class="mb-3">
            <label class="form-label" for="login">Логин</label>
            <input
              class="form-control <%= formState.hasFieldError('login') ? 'is-invalid' : '' %>"
              id="login"
              name="login"
              type="text"
              value="<%= formState.fields.login %>"
              placeholder="Например, River26"
            />
            <div class="form-hint">Используйте логин, указанный при регистрации.</div>
            <% if (formState.hasFieldError("login")) { %>
              <div class="invalid-feedback d-block"><%= formState.getFieldError("login") %></div>
            <% } %>
          </div>

          <div class="mb-4">
            <label class="form-label" for="password">Пароль</label>
            <input
              class="form-control <%= formState.hasFieldError('password') ? 'is-invalid' : '' %>"
              id="password"
              name="password"
              type="password"
            />
            <div class="form-hint">Пароль чувствителен к регистру символов.</div>
            <% if (formState.hasFieldError("password")) { %>
              <div class="invalid-feedback d-block"><%= formState.getFieldError("password") %></div>
            <% } %>
          </div>

          <button type="submit" class="btn btn-primary w-100">Войти</button>
        </form>

        <p class="mt-3 mb-0 text-center">
          <a href="/register" class="link-accent">Еще не зарегистрированы? Регистрация</a>
        </p>
      </div>
    </div>
  </section>
</main>

<%- include("../partials/footer") %>
