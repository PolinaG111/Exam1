<%- include("../partials/head", { pageTitle }) %>
<%- include("../partials/header") %>
<%- include("../partials/flash") %>

<main class="container py-5">
  <section class="hero-card auth-card mx-auto">
    <div class="row g-4 align-items-center">
      <div class="col-lg-6">
        <p class="eyebrow">Авторизация пользователя</p>
        <h1 class="display-6 fw-bold mb-3">Вход в портал записи на курсы управления водным транспортом</h1>
        <p class="text-muted mb-0">
          Записывайтесь на обучение по катерам, яхтам и круизным лайнерам в одном личном кабинете.
        </p>
        <img class="feature-image feature-image-logo mt-4" src="/assets/logo.jpg" alt="Бренд Водить.РФ" />
      </div>

      <div class="col-lg-6">
        <form action="/login" method="post" class="glass-panel">
          <div class="mb-3">
            <label class="form-label" for="login">Логин</label>
            <input
              class="form-control <%= formState.hasFieldError('login') ? 'is-invalid' : '' %>"
              id="login"
              name="login"
              type="text"
              value="<%= formState.fields.login %>"
              placeholder="Например, River26"
            />
            <div class="form-hint">Используйте логин, указанный при регистрации.</div>
            <% if (formState.hasFieldError("login")) { %>
              <div class="invalid-feedback d-block"><%= formState.getFieldError("login") %></div>
            <% } %>
          </div>

          <div class="mb-4">
            <label class="form-label" for="password">Пароль</label>
            <input
              class="form-control <%= formState.hasFieldError('password') ? 'is-invalid' : '' %>"
              id="password"
              name="password"
              type="password"
            />
            <div class="form-hint">Пароль чувствителен к регистру символов.</div>
            <% if (formState.hasFieldError("password")) { %>
              <div class="invalid-feedback d-block"><%= formState.getFieldError("password") %></div>
            <% } %>
          </div>

          <button type="submit" class="btn btn-primary w-100">Войти</button>
        </form>

        <p class="mt-3 mb-0 text-center">
          <a href="/register" class="link-accent">Еще не зарегистрированы? Регистрация</a>
        </p>
      </div>
    </div>
  </section>
</main>

<%- include("../partials/footer") %>
