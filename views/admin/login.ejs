<%- include("../partials/head", { pageTitle }) %>
<%- include("../partials/header") %>
<%- include("../partials/flash") %>

<main class="container py-5">
  <section class="hero-card auth-card mx-auto">
    <div class="row g-4 align-items-center">
      <div class="col-lg-6">
        <p class="eyebrow">Управление заявками</p>
        <h1 class="display-6 fw-bold mb-3">Вход администратора</h1>
        <p class="text-muted mb-0">
          Доступ к просмотру всех заявок и изменению статусов обучения.
        </p>
        <img class="feature-image feature-image-logo mt-4" src="/assets/logo.jpg" alt="Бренд Водить.РФ" />
      </div>

      <div class="col-lg-6">
        <form action="/admin/login" method="post" class="glass-panel">
          <div class="mb-3">
            <label class="form-label" for="login">Логин</label>
            <input
              class="form-control <%= formState.hasFieldError('login') ? 'is-invalid' : '' %>"
              id="login"
              name="login"
              type="text"
              value="<%= formState.fields.login %>"
            />
            <% if (formState.hasFieldError("login")) { %>
              <div class="invalid-feedback d-block"><%= formState.getFieldError("login") %></div>
            <% } %>
          </div>

          <div class="mb-4">
            <label class="form-label" for="password">Пароль</label>
            <input
              class="form-control <%= formState.hasFieldError('password') ? 'is-invalid' : '' %>"
              id="password"
              name="password"
              type="password"
            />
            <% if (formState.hasFieldError("password")) { %>
              <div class="invalid-feedback d-block"><%= formState.getFieldError("password") %></div>
            <% } %>
          </div>

          <button type="submit" class="btn btn-primary w-100">Войти как администратор</button>
        </form>
      </div>
    </div>
  </section>
</main>

<%- include("../partials/footer") %>
