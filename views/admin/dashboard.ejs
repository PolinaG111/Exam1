<%- include("../partials/head", { pageTitle }) %>
<%- include("../partials/header") %>
<%- include("../partials/flash", { errors: [] }) %>

<main class="container py-5">
  <section class="hero-card">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
      <div>
        <p class="eyebrow">Панель администратора</p>
        <h1 class="display-6 fw-bold mb-2">Все заявки пользователей</h1>
        <p class="text-muted mb-0">
          Авторизация выполнена под учетной записью <strong><%= isAdmin ? "Admin26" : "" %></strong>.
        </p>
      </div>
      <div class="admin-brand-chip">
        <img src="/assets/logo.jpg" alt="Логотип" />
      </div>
    </div>

    <% if (applications.length === 0) { %>
      <p class="text-muted mb-0">В системе пока нет заявок.</p>
    <% } else { %>
      <div class="table-responsive">
        <table class="table table-theme align-middle mb-0">
          <thead>
            <tr>
              <th>ID</th>
              <th>Пользователь</th>
              <th>Контакты</th>
              <th>Транспорт</th>
              <th>Старт</th>
              <th>Оплата</th>
              <th>Статус</th>
            </tr>
          </thead>
          <tbody>
            <% applications.forEach((application) => { %>
              <tr>
                <td>#<%= application.id %></td>
                <td>
                  <strong><%= application.fullName %></strong><br />
                  <span class="text-muted small"><%= application.login %></span>
                </td>
                <td>
                  <span class="small"><%= application.phone %></span><br />
                  <span class="text-muted small"><%= application.email %></span>
                </td>
                <td><%= application.transportType %></td>
                <td><%= application.startDate %></td>
                <td><%= application.paymentMethod %></td>
                <td>
                  <form action="/admin/applications/<%= application.id %>/status" method="post" class="d-flex gap-2">
                    <select class="form-select form-select-sm" name="status">
                      <% statuses.forEach((status) => { %>
                        <option value="<%= status %>" <%= application.status === status ? "selected" : "" %>>
                          <%= status %>
                        </option>
                      <% }) %>
                    </select>
                    <button type="submit" class="btn btn-primary btn-sm">Сохранить</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </section>
</main>

<%- include("../partials/footer") %>
